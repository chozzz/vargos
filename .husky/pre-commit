#!/bin/sh

# Scan for PII/secrets before linting
check_pii() {
  git diff --cached --name-only | while read file; do
    # Skip husky hook files (they contain regex patterns as code, not secrets)
    if echo "$file" | grep -q '\.husky/'; then
      continue
    fi
    if [ -f "$file" ] && ! file "$file" | grep -q "binary"; then
      if grep -iE "phone.*[0-9]{3}.*[0-9]{3}|[0-9]{3}-[0-9]{2}-[0-9]{4}|api_key[[:space:]]*=|api-key[[:space:]]*=|password[[:space:]]*[:=]|secret[[:space:]]*[:=]|token[[:space:]]*=|authorization[[:space:]]*=" "$file" > /dev/null 2>&1; then
        echo "❌ BLOCKED: Potential PII/secret detected in $file"
        echo "   Review and remove before committing"
        echo "   (Or use: git commit --no-verify to skip)"
        exit 1
      fi
    fi
  done
}

check_pii || exit 1

# Run standard precommit checks
pnpm run precommit
