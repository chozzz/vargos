{
  "name": "vargos",
  "version": "2.0.3",
  "description": "Self-hosted agent OS with persistent memory, multi-channel presence, tools, scheduling, and sub-agent orchestration",
  "license": "Apache-2.0",
  "author": "Vadi Taslim",
  "repository": {
    "type": "git",
    "url": "https://github.com/chozzz/vargos.git"
  },
  "homepage": "https://github.com/chozzz/vargos",
  "bugs": "https://github.com/chozzz/vargos/issues",
  "keywords": [
    "mcp",
    "agent",
    "ai",
    "runtime",
    "self-hosted",
    "llm",
    "tools",
    "whatsapp",
    "telegram"
  ],
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "bin": {
    "vargos": "./dist/index.js"
  },
  "scripts": {
    "start": "tsx index.ts",
    "build": "tsc",
    "prepare": "husky && tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint 'gateway/**/*.ts' 'services/**/*.ts' 'lib/**/*.ts' 'index.ts' 'vitest.config.ts' '**/__tests__/**/*.ts' && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "precommit": "pnpm exec lint-staged && pnpm run typecheck && pnpm run test:run",
    "postinstall": "pnpm rebuild better-sqlite3"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@mariozechner/pi-agent-core": "^0.67.68",
    "@mariozechner/pi-coding-agent": "^0.67.68",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "cron": "^4.4.0",
    "pg": "^8.18.0",
    "pgvector": "^0.2.1",
    "pino": "^10.3.1",
    "playwright": "^1.58.1",
    "qrcode-terminal": "^0.12.0",
    "tinyglobby": "^0.2.15",
    "turndown": "^7.2.4",
    "ws": "^8.18.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cron": "^2.4.3",
    "@types/node": "^25.2.1",
    "@types/pg": "^8.16.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}
